# Rinomina questo file in ".env" e compila i valori

# MongoDB locale:
# MONGODB_URI=mongodb://localhost/bloglist

# MongoDB Atlas (sostituisci i segnaposto):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bloglist?retryWrites=true&w=majority

PORT=3003
SECRET=your_jwt_secret_here
