@base = http://localhost:3003/api/blogs
@users = http://localhost:3003/api/users
@login = http://localhost:3003/api/login
@token = INCOLLA_TOKEN_JWT

### POST — crea un utente
POST {{users}}
Content-Type: application/json

{
  "username": "mluukkai",
  "name": "Matti Luukkainen",
  "password": "salainen"
}

###

### GET — tutti gli utenti
GET {{users}}

###

### POST — login
POST {{login}}
Content-Type: application/json

{
  "username": "mluukkai",
  "password": "salainen"
}

### GET — tutti i blog
GET {{base}}

###

### POST — crea un blog completo
POST {{base}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Go To Statement Considered Harmful",
  "author": "Edsger W. Dijkstra",
  "url": "https://homepages.cwi.nl/~storm/teaching/reader/Dijkstra68.pdf",
  "likes": 5
}

###

### POST — blog senza likes (defaults a 0)
POST {{base}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "The Pragmatic Programmer",
  "author": "Andy Hunt",
  "url": "https://pragprog.com/titles/tpp20/"
}

###

### GET — singolo blog (sostituisci l'id)
# GET {{base}}/INSERISCI_ID_QUI

###

### PUT — aggiorna i likes
# PUT {{base}}/INSERISCI_ID_QUI
# Content-Type: application/json
#
# { "likes": 42 }

###

### DELETE — elimina un blog
# DELETE {{base}}/INSERISCI_ID_QUI
# Authorization: Bearer {{token}}
